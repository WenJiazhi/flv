#!name=Douyin Live Switch
#!desc=Capture Douyin FLV targets from 302, dispatch JSON, or direct 200 responses, then replace matching live traffic.
#!author=Codex
#!homepage=https://nsloon.app/docs/Plugin/
#!loon_version=3.2.1(733)
#!system=iOS,iPadOS

[Argument]
override_url = input,"",tag=Override FLV URL,desc=Optional. Leave empty to use the most recently captured target URL.
capture_enabled = switch,true,tag=Capture Switch,desc=Turn on to lock the first matched target. Turn off and on again to capture a new one.
replace_enabled = switch,false,tag=Replace Switch,desc=Turn on to replace live traffic according to the captured target type.

[Script]
http-request ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_redirect_douyin_direct_request.js?v=20260329argfix1,tag=Replace Direct 200,argument=[{override_url}],enable={replace_enabled}
http-request ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/ script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_capture_toggle_sync.js?v=20260329argfix1,tag=Sync Capture Switch,argument=[{capture_enabled}]
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.*cdn_type=dispatch.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_capture_douyin_stream.js?v=20260329argfix1,requires-body=true,tag=Capture Dispatch JSON,argument=[{capture_enabled}]
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.*cdn_type=dispatch.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_rewrite_douyin_dispatch_json.js?v=20260329argfix1,requires-body=true,tag=Rewrite Dispatch JSON,argument=[{override_url}],enable={replace_enabled}
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_capture_douyin_stream.js?v=20260329argfix1,requires-body=false,tag=Capture FLV Entry,argument=[{capture_enabled}]
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_rewrite_douyin_location.js?v=20260329argfix1,requires-body=false,tag=Rewrite 302 Location,argument=[{override_url}],enable={replace_enabled}

[MITM]
hostname = *.douyincdn.com,*.flive.douyincdn.com,*.douyinliving.com
