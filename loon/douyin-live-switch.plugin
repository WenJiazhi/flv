#!name=抖音直播替换
#!desc=抓取抖音直播 FLV 目标，并按 302、调度 JSON、200 直连三类链路分别替换。
#!author=Codex
#!homepage=https://nsloon.app/docs/Plugin/
#!loon_version=3.2.1(733)
#!system=iOS,iPadOS

[Argument]
override_url = input,"",tag=替换 FLV 地址,desc=可选。留空时使用最近一次成功抓到的目标地址。
capture_enabled = switch,true,tag=抓取开关,desc=打开后只锁定第一条命中的目标流。关闭后再打开，会重新抓取下一条新的目标流。
replace_enabled = switch,false,tag=替换开关,desc=打开后按当前抓到的类型分别替换：302 改 Location，调度 JSON 改 complete_url，200 直连改请求地址。

[Script]
http-request ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_redirect_douyin_direct_request.js?v=20260329cnui1,tag=200 直连替换,argument=[{override_url}],enable={replace_enabled}
http-request ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/ script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_capture_toggle_sync.js?v=20260329cnui1,tag=抓取开关同步,argument=[{capture_enabled}]
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.*cdn_type=dispatch.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_capture_douyin_stream.js?v=20260329cnui1,requires-body=true,tag=抓取调度 JSON,argument=[{capture_enabled}]
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.*cdn_type=dispatch.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_rewrite_douyin_dispatch_json.js?v=20260329cnui1,requires-body=true,tag=调度 JSON 替换,argument=[{override_url}],enable={replace_enabled}
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_capture_douyin_stream.js?v=20260329cnui1,requires-body=false,tag=抓取 FLV 入口,argument=[{capture_enabled}]
http-response ^https?:\/\/[^\/]*(?:douyincdn\.com|douyinliving\.com)\/.*\.flv.* script-path=https://raw.githubusercontent.com/WenJiazhi/flv/main/loon/loon_rewrite_douyin_location.js?v=20260329cnui1,requires-body=false,tag=302 Location 替换,argument=[{override_url}],enable={replace_enabled}

[MITM]
hostname = *.douyincdn.com,*.flive.douyincdn.com,*.douyinliving.com
